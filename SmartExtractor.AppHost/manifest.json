{
  "$schema": "https://json.schemastore.org/aspire-8.0.json",
  "resources": {
    "smart-extractor-api": {
      "type": "project.v0",
      "path": "../SmartExtractor.Api/SmartExtractor.Api.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{smart-extractor-api.bindings.http.targetPort}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "frontend": {
      "type": "container.v1",
      "build": {
        "context": "../UI/smart-extractor",
        "dockerfile": "../UI/smart-extractor/Dockerfile"
      },
      "env": {
        "NODE_ENV": "development",
        "PORT": "{frontend.bindings.http.targetPort}",
        "NUXT_PUBLIC_API_BASE_URL": "{smart-extractor-api.bindings.https.url}",
        "SMART_EXTRACTOR_API_HTTP": "{smart-extractor-api.bindings.http.url}",
        "services__smart-extractor-api__http__0": "{smart-extractor-api.bindings.http.url}",
        "SMART_EXTRACTOR_API_HTTPS": "{smart-extractor-api.bindings.https.url}",
        "services__smart-extractor-api__https__0": "{smart-extractor-api.bindings.https.url}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 3000
        }
      }
    }
  }
}